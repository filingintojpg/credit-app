  <bpmn:process id="creditApplicationProcess" name="Credit Application Process" isExecutable="true">
    <bpmn:startEvent id="start" name="Start">
      <bpmn:outgoing>Flow_0z45fzy</bpmn:outgoing>
    </bpmn:startEvent>
    <bpmn:serviceTask id="validateApplication" name="Validate Application" camunda:expression="${validateApplicationDelegate.execute(execution)}">
      <bpmn:incoming>Flow_0z45fzy</bpmn:incoming>
      <bpmn:outgoing>Flow_1754rnt</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:sequenceFlow id="Flow_0z45fzy" sourceRef="start" targetRef="validateApplication" />
    <bpmn:sequenceFlow id="Flow_1754rnt" sourceRef="validateApplication" targetRef="checkConditions" />
    <bpmn:exclusiveGateway id="checkConditions" name="Suits?">
      <bpmn:incoming>Flow_1754rnt</bpmn:incoming>
      <bpmn:outgoing>Flow_0zdccoz</bpmn:outgoing>
      <bpmn:outgoing>Flow_154a8lv</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:serviceTask id="approveApplication" name="Approve Application" camunda:expression="${approveApplicationDelegate.execute(execution)}">
      <bpmn:incoming>Flow_0zdccoz</bpmn:incoming>
      <bpmn:outgoing>Flow_0w90upv</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:serviceTask id="rejectApplication" name="Reject Application" camunda:expression="${rejectApplicationDelegate.execute(execution)}">
      <bpmn:incoming>Flow_154a8lv</bpmn:incoming>
      <bpmn:outgoing>Flow_1kzpb4g</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:endEvent id="end" name="End">
      <bpmn:incoming>Flow_0w90upv</bpmn:incoming>
      <bpmn:incoming>Flow_1kzpb4g</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:sequenceFlow id="Flow_0w90upv" sourceRef="approveApplication" targetRef="end" />
    <bpmn:sequenceFlow id="Flow_1kzpb4g" sourceRef="rejectApplication" targetRef="end" />
    <bpmn:sequenceFlow id="Flow_0zdccoz" name="Approved" sourceRef="checkConditions" targetRef="approveApplication">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">${approved == true}</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="Flow_154a8lv" name="Rejected" sourceRef="checkConditions" targetRef="rejectApplication">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">${approved == false}</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
  </bpmn:process>
