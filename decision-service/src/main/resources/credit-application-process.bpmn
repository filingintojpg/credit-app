        <bpmndi:BPMNLabel />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Event_0l2wz6i_di" bpmnElement="end">
        <dc:Bounds x="842" y="182" width="36" height="36" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="850" y="223" width="20" height="14" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNEdge id="Flow_0z45fzy_di" bpmnElement="Flow_0z45fzy">
        <di:waypoint x="218" y="200" />
        <di:waypoint x="270" y="200" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_0py8zh2_di" bpmnElement="Flow_0py8zh2">
