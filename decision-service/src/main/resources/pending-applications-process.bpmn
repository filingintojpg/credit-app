  <bpmn:process id="pendingApplicationsProcess" name="Pending Applications Process" isExecutable="true">
    <bpmn:startEvent id="timerStart" name="Timer Start">
      <bpmn:outgoing>Flow_04u6b96</bpmn:outgoing>
      <bpmn:timerEventDefinition id="TimerEventDefinition_0vzkkle">
        <bpmn:timeCycle xsi:type="bpmn:tFormalExpression">R/PT10M</bpmn:timeCycle>
      </bpmn:timerEventDefinition>
    </bpmn:startEvent>
    <bpmn:serviceTask id="loadPendingApplications" name="Load Pending Applications" camunda:expression="${loadPendingApplicationsDelegate.execute(execution)}">
      <bpmn:incoming>Flow_04u6b96</bpmn:incoming>
      <bpmn:outgoing>Flow_08voc9w</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:sequenceFlow id="Flow_04u6b96" sourceRef="timerStart" targetRef="loadPendingApplications" />
    <bpmn:callActivity id="processPendingApplication" name="Process Pending Application" calledElement="creditApplicationProcess">
      <bpmn:extensionElements>
        <camunda:in source="applicationId" target="applicationId" />
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_08voc9w</bpmn:incoming>
      <bpmn:outgoing>Flow_1r9sw91</bpmn:outgoing>
      <bpmn:multiInstanceLoopCharacteristics camunda:collection="${pendingApplicationIds}" camunda:elementVariable="applicationId" />
    </bpmn:callActivity>
    <bpmn:sequenceFlow id="Flow_08voc9w" sourceRef="loadPendingApplications" targetRef="processPendingApplication" />
    <bpmn:endEvent id="end" name="End">
      <bpmn:incoming>Flow_1r9sw91</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:sequenceFlow id="Flow_1r9sw91" sourceRef="processPendingApplication" targetRef="end" />
  </bpmn:process>
