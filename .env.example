DB_NAME=credit_db
DB_USERNAME=admin
DB_PASSWORD=admin
DB_HOST=localhost
DB_PORT=5432
APPLICATION_SERVICE_PORT=8080
DECISION_SERVICE_PORT=8090
CAMUNDA_USERNAME=admin
CAMUNDA_PASSWORD=admin

# Last line is an example for copying to IntelliJ Idea Project's environment variables.
#
# Windows: CTRL + SHIFT + A
# macOS: CMD + SHIFT + A
# -> Edit Configurations
# -> choose project (service)
# -> Modify options
# -> enable Environment Variables
#
# Copy without comment symbol and space to both (application, decision) services.
#
# DB_USERNAME=admin;DB_PASSWORD=admin;DB_NAME=credit_db;DB_HOST=localhost;DB_PORT=5432;APPLICATION_SERVICE_PORT=8080;DECISION_SERVICE_PORT=8090;CAMUNDA_USERNAME=admin;CAMUNDA_PASSWORD=admin
